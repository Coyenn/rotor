{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "transform": "./plugins/prefix-string.js",
        "prefix": "after",
        "after": true
      },
      {
        "transform": "./plugins/prefix-string-named.js",
        "import": "configTransformer",
        "type": "config",
        "prefix": "before"
      }
    ]
  }
}
